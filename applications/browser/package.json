{
  "private": true,
  "name": "@arc-studio/browser",
  "version": "0.1.0-alpha",
  "description": "ARC Studio — Browser Application",
  "scripts": {
    "build": "theia build --mode development",
    "build:prod": "theia build --mode production",
    "rebuild": "theia rebuild:browser --cacheRoot ../..",
    "start": "theia start --port 3000 --hostname 127.0.0.1",
    "start:arc": "node ../../scripts/start-browser-arc.mjs",
    "start:stub": "node ../../scripts/start-browser-stub.mjs",
    "start:debug": "theia start --port 3000 --hostname 127.0.0.1 --loglevel=debug",
    "watch": "theia build --watch --mode development",
    "clean": "rimraf lib src-gen",
    "check": "tsc --noEmit -p .",
    "test": "echo 'no unit tests for app shell' && exit 0"
  },
  "dependencies": {
    "@theia/core": "1.71.0",
    "@theia/editor": "1.71.0",
    "@theia/filesystem": "1.71.0",
    "@theia/markers": "1.71.0",
    "@theia/messages": "1.71.0",
    "@theia/monaco": "1.71.0",
    "@theia/navigator": "1.71.0",
    "@theia/preferences": "1.71.0",
    "@theia/process": "1.71.0",
    "@theia/terminal": "1.71.0",
    "@theia/workspace": "1.71.0",
    "@theia/output": "1.71.0",
    "@theia/search-in-workspace": "1.71.0",
    "@theia/getting-started": "1.71.0",
    "@theia/keymaps": "1.71.0",
    "arc-extension": "workspace:*",
    "arc-core": "workspace:*",
    "arc-workflows": "workspace:*",
    "arc-runs": "workspace:*",
    "arc-schemas": "workspace:*",
    "arc-context": "workspace:*",
    "arc-audit": "workspace:*",
    "arc-health": "workspace:*",
    "arc-event-stream": "workspace:*",
    "arc-product": "workspace:*",
    "arc-settings": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "1.71.0",
    "rimraf": "^5.0.10"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "ARC Studio",
        "reloadOnReconnect": true,
        "preferences": {
          "files.enableTrash": true,
          "security.workspace.trust.enabled": true,
          "workbench.colorTheme": "Dark+ (default dark)"
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": 30000
      }
    }
  },
  "theiaPluginsDir": "../../plugins"
}
