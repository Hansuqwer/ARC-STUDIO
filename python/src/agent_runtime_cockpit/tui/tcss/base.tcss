/* ARC Studio TUI — Base layout. Colors come from theme tokens injected by
   ArcApp.get_css_variables() so /theme re-skins the chrome live. */

Screen {
    layout: vertical;
    background: $background;
    color: $foreground;
}

#banner {
    height: 3;
    background: $surface;
    border-bottom: solid $border;
    padding: 0 1;
}

#transcript {
    height: 1fr;
    background: $background;
    overflow-y: auto;
}

#status-bar {
    height: 1;
    background: $surface;
    border-top: solid $border;
    color: $muted;
    padding: 0 1;
}

#input-area {
    height: auto;
    min-height: 4;
    max-height: 12;
    background: $input-bg;
    border-top: solid $border;
    padding: 0 1;
}

#prompt-input {
    background: $input-bg;
    color: $foreground;
    border: none;
    padding: 0 1;
    height: 3;
}

#send-hint {
    color: $muted;
    padding: 0 1;
    height: 1;
}

#slash-menu {
    background: $surface;
    border: solid $border;
    height: auto;
    max-height: 12;
    margin: 0 2;
    display: none;
}

#slash-menu.visible {
    display: block;
}

#approval-bar {
    background: $surface;
    border: solid $warning;
    height: 3;
    padding: 0 1;
    display: none;
}

#approval-bar.visible {
    display: block;
}
