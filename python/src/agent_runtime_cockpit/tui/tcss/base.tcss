/* ARC Studio TUI — Base layout */

Screen {
    background: #1a1b26;
    color: #c0caf5;
}

#banner {
    height: 3;
    background: #24283b;
    border-bottom: solid #3b4261;
    padding: 0 1;
}

#transcript {
    background: #1a1b26;
    overflow-y: scroll;
}

#status-bar {
    height: 1;
    background: #24283b;
    border-top: solid #3b4261;
    color: #565f89;
    padding: 0 1;
}

#input-area {
    height: auto;
    min-height: 3;
    max-height: 40%;
    background: #1f2335;
    border-top: solid #3b4261;
    padding: 0 1;
}

#prompt-input {
    background: #1f2335;
    color: #c0caf5;
    border: none;
    padding: 0 1;
}

#prompt-input:focus {
    border: none;
}

#send-hint {
    color: #565f89;
    text-align: right;
    padding: 0 1;
    height: 1;
}

#slash-menu {
    background: #24283b;
    border: solid #3b4261;
    max-height: 12;
    margin: 0 2;
    display: none;
}

#slash-menu.visible {
    display: block;
}

#approval-bar {
    background: #24283b;
    border: solid #e0af68;
    height: 5;
    padding: 0 1;
    display: none;
}

#approval-bar.visible {
    display: block;
}

#side-panel {
    width: 40%;
    background: #24283b;
    border-left: solid #3b4261;
    display: none;
}

#side-panel.visible {
    display: block;
}
