{
  "private": true,
  "name": "arc-theia-studio",
  "version": "0.1.0-alpha",
  "description": "ARC Studio — Agent Runtime Cockpit IDE (Eclipse Theia-based)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "applications/browser",
    "applications/electron",
    "theia-extensions/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "pnpm install",
    "build": "pnpm -r build",
    "build:browser": "pnpm --filter @arc-studio/browser build",
    "build:electron": "pnpm --filter @arc-studio/electron build",
    "start:browser": "pnpm --filter @arc-studio/browser start",
    "start:browser:arc": "pnpm --filter @arc-studio/browser start:arc",
    "start:browser:stub": "pnpm --filter @arc-studio/browser start:stub",
    "start:electron": "pnpm --filter @arc-studio/electron start",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @arc-studio/e2e-tests test",
    "typecheck": "tsc -b tsconfig.check.json --pretty",
    "check:pr": "bash scripts/check-pr.sh && pnpm typecheck",
    "package:electron": "pnpm --filter @arc-studio/electron package:release",
    "package:electron:dir": "pnpm --filter @arc-studio/electron package:dir",
    "check:licenses": "bash scripts/check-licenses.sh",
    "check": "pnpm -r check",
    "clean": "pnpm -r clean && rimraf node_modules",
    "download:plugins": "theia download:plugins --rate-limit=15 --parallel=false",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@vscode/ripgrep": "1.17.1"
    }
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {}
}
