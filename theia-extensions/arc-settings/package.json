{
  "name": "arc-settings",
  "version": "0.1.0-alpha",
  "description": "ARC Studio settings — preferences, daemon path, Python env, extension toggles",
  "keywords": ["theia-extension"],
  "license": "Apache-2.0",
  "files": ["lib", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf lib *.tsbuildinfo",
    "check": "echo 'arc-settings check ok'",
    "test": "echo 'arc-settings test ok'"
  },
  "theiaExtensions": [{ "frontend": "lib/browser/arc-settings-frontend-module" }],
  "dependencies": { "@theia/core": "1.71.0", "@theia/preferences": "1.71.0", "arc-core": "workspace:*" },
  "devDependencies": { "@theia/cli": "1.71.0", "rimraf": "^5.0.10", "typescript": "^5.4.5" }
}
