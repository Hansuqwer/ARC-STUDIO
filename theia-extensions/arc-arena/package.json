{
  "name": "arc-arena",
  "version": "0.1.0-alpha",
  "description": "ARC Arena — LM Arena model battle, direct chat, code generation, and agent preview for ARC Studio",
  "keywords": ["theia-extension"],
  "license": "Apache-2.0",
  "files": ["lib", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf lib *.tsbuildinfo",
    "check": "echo 'arc-arena check ok'",
    "test": "node --test --test-reporter=spec ./test/**/*.test.js"
  },
  "theiaExtensions": [
    { "frontend": "lib/browser/arc-arena-frontend-module" }
  ],
  "dependencies": {
    "@theia/core": "1.71.0",
    "arc-core": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "1.71.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.4.5"
  }
}
