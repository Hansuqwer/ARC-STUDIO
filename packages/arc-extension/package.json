{
  "name": "arc-extension",
  "version": "0.6.0-alpha",
  "description": "ARC Studio Theia Extension",
  "license": "EPL-2.0 OR GPL-2.0 WITH Classpath-exception-2.0",
  "main": "lib/node/arc-extension-backend-module.js",
  "typings": "lib/node/arc-extension-backend-module.d.ts",
  "dependencies": {
    "@theia/core": "^1.71.0",
    "@theia/filesystem": "^1.71.0",
    "@theia/navigator": "^1.71.0",
    "@theia/terminal": "^1.71.0",
    "@theia/workspace": "^1.71.0",
    "@types/fs-extra": "^11.0.4",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.0.0",
    "@types/jest-axe": "^3.5.9",
    "jest": "^29.0.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "prepare": "pnpm run clean && pnpm run build",
    "clean": "rimraf lib",
    "build": "tsc && pnpm run copy-assets",
    "copy-assets": "mkdir -p lib/browser/style && cp src/browser/style/*.css lib/browser/style/",
    "watch": "tsc -w",
    "lint": "echo 'Linting not configured yet'",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "lib",
    "src"
  ],
  "theiaExtensions": [
    {
      "frontend": "lib/browser/arc-extension-frontend-module",
      "backend": "lib/node/arc-extension-backend-module"
    }
  ]
}
