{
  "$defs": {
    "NodeType": {
      "enum": [
        "agent",
        "tool",
        "router",
        "start",
        "end",
        "unknown"
      ],
      "title": "NodeType",
      "type": "string"
    },
    "SourceLocation": {
      "properties": {
        "file": {
          "title": "File",
          "type": "string"
        },
        "line": {
          "title": "Line",
          "type": "integer"
        },
        "column": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        }
      },
      "required": [
        "file",
        "line"
      ],
      "title": "SourceLocation",
      "type": "object"
    },
    "WorkflowEdge": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "from_node": {
          "title": "From Node",
          "type": "string"
        },
        "to_node": {
          "title": "To Node",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "conditional": {
          "default": false,
          "title": "Conditional",
          "type": "boolean"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "id",
        "from_node",
        "to_node"
      ],
      "title": "WorkflowEdge",
      "type": "object"
    },
    "WorkflowNode": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/NodeType",
          "default": "unknown"
        },
        "source_location": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "id",
        "label"
      ],
      "title": "WorkflowNode",
      "type": "object"
    }
  },
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "runtime": {
      "title": "Runtime",
      "type": "string"
    },
    "source_file": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source File"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/WorkflowNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/WorkflowEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "entry_points": {
      "items": {
        "type": "string"
      },
      "title": "Entry Points",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "id",
    "name",
    "runtime"
  ],
  "title": "WorkflowInfo",
  "type": "object"
}