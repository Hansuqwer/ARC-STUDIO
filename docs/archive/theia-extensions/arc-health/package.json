{
  "name": "arc-health",
  "version": "0.1.0-alpha",
  "description": "ARC Studio health monitor for the local Python daemon",
  "keywords": ["theia-extension"],
  "license": "Apache-2.0",
  "files": ["lib", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf lib *.tsbuildinfo",
    "check": "echo 'arc-health check ok'",
    "test": "echo 'arc-health test ok'"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/arc-health-frontend-module"
    }
  ],
  "dependencies": {
    "@theia/core": "1.71.0",
    "arc-core": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "1.71.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.4.5"
  }
}
