# Copy to .env and fill in real values. Never commit .env.
# Required for paid provider calls (only when ARC_ALLOW_PAID_CALLS=true).
G4F_API_KEY=

# Optional daemon bearer token. If unset, daemon runs unauthenticated on localhost.
# ARC_DAEMON_TOKEN=

# Optional OTLP endpoint for traces.
# ARC_OTLP_ENDPOINT=
