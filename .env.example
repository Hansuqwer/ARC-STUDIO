# Copy to .env and fill in real values. Never commit .env.

# Optional daemon bearer token. If unset, daemon runs unauthenticated on localhost.
# ARC_DAEMON_TOKEN=

# Optional OTLP endpoint for traces.
# ARC_OTLP_ENDPOINT=

# Optional local development/runtime toggles.
# ARC_DEBUG=0
# ARC_USE_FIXTURE_RUNTIME=0
# ARC_MOCK_CONTEXT7=0

# Optional research/search integrations.
# ARC_CONTEXT7_API_KEY=
# ARC_SEARCH_PROVIDER=
# ARC_SEARCH_API_KEY=
# GITHUB_TOKEN=

# Optional provider keys. Leave unset unless explicitly needed.
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
# ZHIPU_API_KEY=
# NVIDIA_API_KEY=
# GROQ_API_KEY=

# Optional SwarmGraph gateway config. Tokens are secrets.
# ARC_SWARMGRAPH_GATEWAY_URL=
# ARC_SWARMGRAPH_GATEWAY_TOKEN=

# Explicit sandbox gates. Disabled by default.
# ARC_ENABLE_CONTAINER_SANDBOX=0
# ARC_MICROVM_EXEC_ENABLED=0
# ARC_MICROVM_INTEGRATION=0
# ARC_VZ_REAL_EXEC=0

# Optional sandbox/audit overrides.
# ARC_SANDBOX_AUDIT_DIR=
# ARC_BIN=
